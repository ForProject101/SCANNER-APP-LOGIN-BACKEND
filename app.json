{
  "expo": {
    "name": "Embroidery DT",
    "slug": "embroidery-dt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.embroiderydt.app",
      "versionCode": 1
    },
    "extra": {
      "eas": {
        "projectId": "98fb71e4-9a58-408d-96e9-2cbfca083e7d"
      }
    },
    "plugins": [
      "expo-barcode-scanner"
    ]
  }
}
